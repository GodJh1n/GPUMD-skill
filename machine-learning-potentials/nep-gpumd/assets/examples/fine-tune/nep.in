# Generic fine-tuning template
# Adapt the fine_tune line, type, and species to your base model.
# Descriptor parameters MUST match the base model's nep.restart.
# Only training-control parameters (lambda_*, batch, generation) can vary.
#
# For NEP89-specific templates, see assets/examples/nep89/

fine_tune  base_model.txt base_model.restart
type       2  Mo  S

# Descriptor — locked to base model
version    4
zbl        2
cutoff     6 5
n_max      4 4
basis_size 8 8
l_max      4 2 1
neuron     80

# Training control — adjustable
lambda_e   1.0
lambda_f   1.0
lambda_v   0.1
batch      1000
population 50
generation 5000    # fine-tuning converges faster; increase to 10000-50000 for large domain shifts
